# Servidor Webhook
PORT=3001

# Gemini API Key (Fija para uso personal)
# Obtener en Google AI Studio: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Google Workspace OAuth2 Credentials
# Obtener en Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/callback
