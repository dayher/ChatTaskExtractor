# --- API Keys ---
# Obtén tu clave en Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Credenciales de Google OAuth 2.0 ---
# Crea una credencial de tipo "Aplicación de escritorio" en la consola de Google Cloud
# (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# --- Configuración del Agente de WhatsApp ---
# Emisor del cual deseas extraer las tareas e información valiosa
SENDER_OF_INTEREST=Magely Villa Ermua Hotel
